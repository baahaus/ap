{
  "name": "@blushagent/team",
  "version": "0.1.2",
  "description": "Multi-agent coordination -- peer agents, mailboxes, task queues",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@blushagent/ai": "workspace:*",
    "@blushagent/core": "workspace:*",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "author": "AP.HAUS",
  "repository": {
    "type": "git",
    "url": "https://github.com/baahaus/blush.git",
    "directory": "packages/team"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["multi-agent", "worktree", "mailbox", "task-queue", "coordination"]
}
